# PostgreSQL Database configuration
POSTGRES_DB=echotalk
POSTGRES_USER=echotalk
POSTGRES_PASSWORD=echotalk_secret

# Spring Boot / Backend Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/echotalk
SPRING_DATASOURCE_USERNAME=echotalk
SPRING_DATASOURCE_PASSWORD=echotalk_secret

# Redis Configuration
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=echotalk-super-secret-jwt-key-change-in-production-2024

# SocketIO
SOCKETIO_PORT=8081
